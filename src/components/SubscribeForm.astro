---
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang?: Lang;
  compact?: boolean;
}

const { lang = 'zh', compact = false } = Astro.props;
const t = useTranslations(lang);
---

<div class:list={['subscribe-form', { compact }]}>
  {!compact && (
    <div class="subscribe-header">
      <h3>{t('subscribe.title')}</h3>
      <p>{t('subscribe.desc')}</p>
    </div>
  )}
  <!--
    使用 Buttondown 免费邮件订阅服务:
    1. 注册 https://buttondown.com（免费版支持100人）
    2. 将下方 action 中的 beyondthechart 替换为你的 newsletter 名称
    3. 例如注册名为 beyond-the-chart，则 action="https://buttondown.com/api/emails/embed-subscribe/beyond-the-chart"
  -->
  <form
    action="https://buttondown.com/api/emails/embed-subscribe/beyondthechart"
    method="post"
    target="_blank"
    class="subscribe-row"
  >
    <input
      type="email"
      name="email"
      placeholder={t('subscribe.placeholder')}
      required
      autocomplete="email"
    />
    <button type="submit">{t('subscribe.btn')}</button>
  </form>
  <p class="subscribe-note">{t('subscribe.privacy')}</p>
</div>

<style>
  .subscribe-form {
    margin-top: 1.5rem;
  }
  .subscribe-header h3 {
    color: var(--gold);
    font-size: 1.2rem;
    margin-bottom: 0.4rem;
  }
  .subscribe-header p {
    color: var(--text-muted);
    font-size: 0.95rem;
    margin-bottom: 1rem;
  }
  .subscribe-row {
    display: flex;
    gap: 0.6rem;
    max-width: 480px;
  }
  .subscribe-row input {
    flex: 1;
    padding: 0.65rem 1rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 4px;
    color: var(--text);
    font-size: 0.9rem;
    font-family: inherit;
    outline: none;
    transition: border-color 0.2s;
  }
  .subscribe-row input::placeholder {
    color: var(--text-muted);
    opacity: 0.6;
  }
  .subscribe-row input:focus {
    border-color: var(--gold-dim);
  }
  .subscribe-row button {
    padding: 0.65rem 1.5rem;
    background: transparent;
    border: 1px solid var(--gold);
    border-radius: 4px;
    color: var(--gold);
    font-size: 0.9rem;
    font-family: inherit;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.2s, color 0.2s;
  }
  .subscribe-row button:hover {
    background: var(--gold);
    color: var(--bg);
  }
  .subscribe-note {
    color: var(--text-muted);
    font-size: 0.75rem;
    margin-top: 0.5rem;
    opacity: 0.7;
  }
  .compact {
    margin-top: 0;
  }
  .compact .subscribe-row {
    max-width: 100%;
  }
  @media (max-width: 480px) {
    .subscribe-row {
      flex-direction: column;
    }
    .subscribe-row button {
      width: 100%;
    }
  }
</style>
