---
import type { Lang } from '../i18n/ui';
import { useTranslations, getLocalePath } from '../i18n/utils';

interface Props {
  lang?: Lang;
}

const { lang = 'zh' } = Astro.props;
const t = useTranslations(lang);
const base = import.meta.env.BASE_URL;

const navItems = [
  { label: t('nav.story'), href: getLocalePath(`${base}story/`, lang) },
  { label: t('nav.characters'), href: getLocalePath(`${base}characters/`, lang) },
  { label: t('nav.world'), href: getLocalePath(`${base}world/`, lang) },
  { label: t('nav.interact'), href: getLocalePath(`${base}interact/`, lang) },
  { label: t('nav.videos'), href: getLocalePath(`${base}videos/`, lang) },
  { label: t('nav.about'), href: getLocalePath(`${base}about/`, lang) },
];

const switchLang = lang === 'zh' ? 'en' : 'zh';
const switchLabel = lang === 'zh' ? 'EN' : '中文';
const switchHref = lang === 'zh'
  ? `/en${Astro.url.pathname}`
  : Astro.url.pathname.replace(/^\/en/, '') || '/';
---

<nav class="navbar">
  <div class="nav-inner container">
    <a class="nav-brand" href={getLocalePath(base, lang)}>{t('nav.brand')}</a>
    <button class="nav-toggle" aria-label={t('nav.menu')} id="nav-toggle">
      <span></span><span></span><span></span>
    </button>
    <ul class="nav-links" id="nav-links">
      {navItems.map(item => (
        <li><a href={item.href}>{item.label}</a></li>
      ))}
      <li class="lang-switch">
        <a href={switchHref} class="lang-btn">{switchLabel}</a>
      </li>
    </ul>
  </div>
</nav>

<style>
  .navbar {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(6, 14, 26, 0.92);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--border);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 60px;
  }
  .nav-brand {
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--gold) !important;
    letter-spacing: 0.1em;
  }
  .nav-links {
    display: flex;
    list-style: none;
    gap: 2rem;
    align-items: center;
  }
  .nav-links a {
    color: var(--text-muted);
    font-size: 0.95rem;
    transition: color 0.2s;
  }
  .nav-links a:hover {
    color: var(--gold);
  }
  .lang-btn {
    display: inline-block;
    padding: 0.25rem 0.6rem;
    border: 1px solid var(--gold-dim);
    border-radius: 3px;
    font-size: 0.8rem;
    letter-spacing: 0.05em;
    color: var(--gold-dim) !important;
    transition: background 0.2s, color 0.2s;
  }
  .lang-btn:hover {
    background: var(--gold);
    color: var(--navy) !important;
  }
  .nav-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    flex-direction: column;
    gap: 5px;
  }
  .nav-toggle span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--text);
    transition: 0.2s;
  }
  @media (max-width: 768px) {
    .nav-toggle { display: flex; }
    .nav-links {
      display: none;
      position: absolute;
      top: 60px;
      left: 0;
      right: 0;
      background: var(--navy);
      flex-direction: column;
      padding: 1rem 1.5rem;
      gap: 0.8rem;
      border-bottom: 1px solid var(--border);
    }
    .nav-links.open { display: flex; }
  }
</style>

<script>
  document.getElementById('nav-toggle')?.addEventListener('click', () => {
    document.getElementById('nav-links')?.classList.toggle('open');
  });
</script>
