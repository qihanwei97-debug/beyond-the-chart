---
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang?: Lang;
}

const { lang = 'zh' } = Astro.props;
const t = useTranslations(lang);
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <span class="footer-title">{t('footer.brand')}</span>
      <span class="footer-sub">{t('footer.sub')}</span>
    </div>
    <div class="footer-links">
      {lang === 'zh' ? (
        <>
          <a href="https://www.xiaohongshu.com/user/profile/65426be0000000000d0068f9" target="_blank" rel="noopener">{t('footer.xiaohongshu')}</a>
          <a href="https://read.douban.com/column/73405503/" target="_blank" rel="noopener">{t('footer.douban')}</a>
        </>
      ) : (
        <>
          <a href="https://x.com/BeyondTheChart_" target="_blank" rel="noopener">Twitter</a>
          <a href="https://read.douban.com/column/73405503/" target="_blank" rel="noopener">{t('footer.douban')}</a>
        </>
      )}
    </div>
    <p class="footer-copy">&copy; {year} {t('footer.copy')}</p>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border);
    padding: 2rem 0;
    margin-top: 4rem;
  }
  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .footer-brand {
    display: flex;
    flex-direction: column;
  }
  .footer-title {
    color: var(--gold);
    font-weight: 600;
    font-size: 1rem;
  }
  .footer-sub {
    color: var(--text-muted);
    font-size: 0.75rem;
    letter-spacing: 0.15em;
  }
  .footer-links {
    display: flex;
    gap: 1.2rem;
  }
  .footer-links a {
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.85rem;
    transition: color 0.2s;
  }
  .footer-links a:hover {
    color: var(--gold);
  }
  .footer-copy {
    color: var(--text-muted);
    font-size: 0.8rem;
  }
  @media (max-width: 768px) {
    .footer-inner {
      flex-direction: column;
      gap: 0.8rem;
      text-align: center;
    }
  }
</style>
