---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import CharacterCard from '../../../components/CharacterCard.astro';
import { useTranslations } from '../../../i18n/utils';
import { charactersEn } from '../../../i18n/content-en';

const lang = 'en' as const;
const t = useTranslations(lang);
const characters = Object.entries(charactersEn).sort(([, a], [, b]) => a.order - b.order);
---

<BaseLayout title={t('chars.title')} lang={lang}>
  <div class="container chars-page">
    <h1>{t('chars.title')}</h1>
    <div class="gold-line"></div>
    <p class="chars-desc">{t('chars.desc')}</p>

    <div class="char-grid">
      {characters.map(([id, c]) => (
        <CharacterCard
          id={id}
          name={c.name}
          role={c.role}
          color={c.color}
          image={c.image}
          brief={c.brief}
          lang={lang}
        />
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .chars-page { padding: 3rem 1.5rem 4rem; }
  .chars-desc { color: var(--text-muted); margin: 0.5rem 0 2rem; max-width: 600px; }
  .char-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 1.5rem; }
</style>
